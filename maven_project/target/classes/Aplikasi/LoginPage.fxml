<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="600" prefWidth="900" style="-fx-background-color: #3E1F0D;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Aplikasi.LoginController">

    <!-- Card Login -->
    <VBox alignment="CENTER_LEFT" maxHeight="420" maxWidth="380" spacing="12" style="-fx-background-color: #FAF3E0;                  -fx-background-radius: 14;                  -fx-padding: 36 40 36 40;">

        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="12">
            <Label style="-fx-font-size: 28px;" text="👤" />
            <VBox spacing="2">
                <Label style="-fx-font-size: 16px;                               -fx-font-weight: bold;                               -fx-text-fill: #3E1F0D;" text="LOGIN PETUGAS" />
                <Label style="-fx-font-size: 11px;                               -fx-text-fill: #8B5E3C;" text="Sistem Antrian Pengambilan Daging Qurban" />
            </VBox>
        </HBox>

        <Separator style="-fx-background-color: #E0C98A;" />

        <!-- Username -->
        <Label style="-fx-font-size: 12px;                       -fx-font-weight: bold;                       -fx-text-fill: #5C2E0E;" text="Username" />
        <TextField fx:id="txtUsername" promptText="Masukkan username" style="-fx-background-color: white;                           -fx-border-color: #D4B870;                           -fx-border-radius: 6;                           -fx-background-radius: 6;                           -fx-padding: 8 12 8 12;                           -fx-font-size: 13px;" />

        <!-- Password -->
        <Label style="-fx-font-size: 12px;                       -fx-font-weight: bold;                       -fx-text-fill: #5C2E0E;" text="Password" />
        <PasswordField fx:id="txtPassword" promptText="Masukkan password" style="-fx-background-color: white;                               -fx-border-color: #D4B870;                               -fx-border-radius: 6;                               -fx-background-radius: 6;                               -fx-padding: 8 12 8 12;                               -fx-font-size: 13px;" />

        <Region prefHeight="6" />

        <!-- Tombol Login -->
        <Button fx:id="btnLogin" maxWidth="Infinity" onAction="#handleLogin" style="-fx-background-color: #5C2E0E;                        -fx-text-fill: #FAF3E0;                        -fx-font-weight: bold;                        -fx-font-size: 13px;                        -fx-padding: 10 0 10 0;                        -fx-background-radius: 8;                        -fx-cursor: hand;" text="Login" />

        <Label alignment="CENTER" maxWidth="Infinity" style="-fx-font-size: 10px;                       -fx-text-fill: #A0622E;" text="© 2026 DKM AL-FALAAH" />
    </VBox>

</StackPane>
