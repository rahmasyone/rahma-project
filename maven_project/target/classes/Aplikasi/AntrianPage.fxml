<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="650" prefWidth="1000" style="-fx-background-color: #FAF3E0;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Aplikasi.AntrianController">
    <left>
        <VBox prefWidth="200" style="-fx-background-color: #3E1F0D;">
            <VBox spacing="4" style="-fx-background-color: #2A1408; -fx-padding: 18 14 14 14;">
                <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #FAF3E0;" text="🕌 DKM AL-FALAAH" />
                <Label style="-fx-font-size: 8px; -fx-text-fill: #7A4520;" text="Sistem Antrian Pengambilan Daging Qurban" />
            </VBox>
            <Button maxWidth="Infinity" onAction="#goDashboard" style="-fx-background-color: transparent; -fx-text-fill: #C4956A; -fx-font-size: 12px; -fx-padding: 12 14; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;" text="  📊  Dashboard" />
            <Button maxWidth="Infinity" onAction="#goDataWarga" style="-fx-background-color: transparent; -fx-text-fill: #C4956A; -fx-font-size: 12px; -fx-padding: 12 14; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;" text="  👤  Data Warga" />
            <Button maxWidth="Infinity" style="-fx-background-color: #5C2E0E; -fx-text-fill: #FAF3E0; -fx-font-size: 12px; -fx-padding: 12 14; -fx-alignment: CENTER_LEFT; -fx-border-color: #D4B870; -fx-border-width: 0 0 0 3;" text="  📋  Antrian" />
            <Button maxWidth="Infinity" onAction="#goPanggil" style="-fx-background-color: transparent; -fx-text-fill: #C4956A; -fx-font-size: 12px; -fx-padding: 12 14; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;" text="  🔊  Panggil Antrian" />
            <Button maxWidth="Infinity" onAction="#goWilayah" style="-fx-background-color: transparent; -fx-text-fill: #C4956A; -fx-font-size: 12px; -fx-padding: 12 14; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;" text="  📍  Wilayah" />
            <Region VBox.vgrow="ALWAYS" />
            <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-background-color: #2A1408; -fx-padding: 12 14;">
                <Label style="-fx-font-size: 18px;" text="👤" textFill="WHITE" />
                <Label style="-fx-font-size: 11px; -fx-text-fill: #E0C98A;" text="User Panitia" />
            </HBox>
        </VBox>
    </left>
    <center>
        <VBox spacing="14" style="-fx-background-color: #FAF3E0;">
            <padding><Insets bottom="16" left="20" right="20" top="16" /></padding>
            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="2">
                    <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #3E1F0D;" text="Antrian" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #8B5E3C;" text="Manajemen nomor antrian harian" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#handleTambah" style="-fx-background-color: #5C2E0E; -fx-text-fill: #FAF3E0; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 6 14; -fx-background-radius: 6; -fx-cursor: hand;" text="+ Tambah Antrian" />
            </HBox>
            <Separator style="-fx-background-color: #E0C98A;" />
            <TableView fx:id="tabelAntrian" style="-fx-background-color: #F0E0B6; -fx-border-color: #D4B870; -fx-border-radius: 8; -fx-background-radius: 8;" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colNomor" prefWidth="100" text="No Antrian" />
                    <TableColumn fx:id="colNama" prefWidth="190" text="Nama Warga" />
                    <TableColumn fx:id="colWilayah" prefWidth="120" text="Wilayah" />
                    <TableColumn fx:id="colStatus" prefWidth="110" text="Status" />
                    <TableColumn fx:id="colDaftar" prefWidth="130" text="Waktu Daftar" />
                    <TableColumn fx:id="colPanggil" prefWidth="140" text="Waktu Dipanggil" />
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
