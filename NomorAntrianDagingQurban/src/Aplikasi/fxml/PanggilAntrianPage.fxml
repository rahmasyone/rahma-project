<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="650" prefWidth="1000" style="-fx-background-color: #FAF3E0;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Aplikasi.PanggilAntrianController">
    <left>
        <VBox prefWidth="200" style="-fx-background-color: #3E1F0D;">
            <VBox spacing="4" style="-fx-background-color: #2A1408; -fx-padding: 18 14 14 14;">
                <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #FAF3E0;" text="🕌 DKM AL-FALAAH" />
                <Label style="-fx-font-size: 8px; -fx-text-fill: #7A4520;" text="Sistem Antrian Pengambilan Daging Qurban" />
            </VBox>
            <Button maxWidth="Infinity" onAction="#goDashboard" style="-fx-background-color: transparent; -fx-text-fill: #C4956A; -fx-font-size: 12px; -fx-padding: 12 14; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;" text="  📊  Dashboard" />
            <Button maxWidth="Infinity" onAction="#goDataWarga" style="-fx-background-color: transparent; -fx-text-fill: #C4956A; -fx-font-size: 12px; -fx-padding: 12 14; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;" text="  👤  Data Warga" />
            <Button maxWidth="Infinity" onAction="#goAntrian" style="-fx-background-color: transparent; -fx-text-fill: #C4956A; -fx-font-size: 12px; -fx-padding: 12 14; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;" text="  📋  Antrian" />
            <Button maxWidth="Infinity" style="-fx-background-color: #5C2E0E; -fx-text-fill: #FAF3E0; -fx-font-size: 12px; -fx-padding: 12 14; -fx-alignment: CENTER_LEFT; -fx-border-color: #D4B870; -fx-border-width: 0 0 0 3;" text="  🔊  Panggil Antrian" />
            <Button maxWidth="Infinity" onAction="#goWilayah" style="-fx-background-color: transparent; -fx-text-fill: #C4956A; -fx-font-size: 12px; -fx-padding: 12 14; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;" text="  📍  Wilayah" />
            <Region VBox.vgrow="ALWAYS" />
            <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-background-color: #2A1408; -fx-padding: 12 14;">
                <Label style="-fx-font-size: 18px;" text="👤" textFill="WHITE" />
                <Label style="-fx-font-size: 11px; -fx-text-fill: #E0C98A;" text="User Panitia" />
            </HBox>
        </VBox>
    </left>
    <center>
        <VBox spacing="16" style="-fx-background-color: #FAF3E0;">
            <padding><Insets bottom="16" left="20" right="20" top="16" /></padding>
            <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #3E1F0D;" text="Panggil Antrian" />
            <Separator style="-fx-background-color: #E0C98A;" />

            <HBox spacing="16" VBox.vgrow="ALWAYS">
                <!-- Panel Sedang Dipanggil -->
                <VBox alignment="CENTER" spacing="14" style="-fx-background-color: #F0E0B6; -fx-background-radius: 12;                              -fx-border-color: #D4B870; -fx-border-radius: 12; -fx-padding: 24;" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #8B5E3C;" text="SEDANG DIPANGGIL" />
                    <!-- Kotak nomor besar -->
                    <StackPane prefHeight="160" prefWidth="160" style="-fx-background-color: #5C2E0E; -fx-background-radius: 14;">
                        <VBox alignment="CENTER" spacing="4">
                            <Label style="-fx-font-size: 11px; -fx-text-fill: #E0C98A;" text="Nomor Antrian" />
                            <Label fx:id="lblNomor" style="-fx-font-size: 56px; -fx-font-weight: bold; -fx-text-fill: #FAF3E0;" text="007" />
                        </VBox>
                    </StackPane>
                    <Label fx:id="lblNamaWarga" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #3E1F0D;" text="Ani Wijayanti" />
                    <Label fx:id="lblWilayah" style="-fx-font-size: 12px; -fx-text-fill: #8B5E3C;" text="RT 02/RW 02 — 09:00 WIB" />
                    <HBox alignment="CENTER" spacing="10">
                        <Button onAction="#handleLewati" style="-fx-background-color: white; -fx-border-color: #D4B870; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 20; -fx-cursor: hand;" text="Lewati" />
                        <Button onAction="#handleSelesai" style="-fx-background-color: #5C2E0E; -fx-text-fill: #FAF3E0; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 8 20; -fx-cursor: hand;" text=" Selesai" />
                    </HBox>
                    <Button maxWidth="Infinity" onAction="#handlePanggil" style="-fx-background-color: #3E1F0D; -fx-text-fill: #FAF3E0; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 8; -fx-padding: 10; -fx-cursor: hand;" text="🔊 Panggil Berikutnya" />
                </VBox>

                <!-- Tabel Menunggu -->
                <VBox spacing="10" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #3E1F0D;" text="Antrian Menunggu" />
                    <TableView fx:id="tabelMenunggu" style="-fx-background-color: #F0E0B6; -fx-border-color: #D4B870; -fx-border-radius: 8; -fx-background-radius: 8;" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colNomor" prefWidth="70" text="No" />
                            <TableColumn fx:id="colNama" prefWidth="160" text="Nama Warga" />
                            <TableColumn fx:id="colWil" prefWidth="120" text="Wilayah" />
                        </columns>
                    </TableView>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>
